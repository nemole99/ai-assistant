{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (Vite + React)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev:web"],
      "port": 3001
    },
    {
      "name": "API Server (Hono)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev:server"],
      "autoPort": true
    },
    {
      "name": "Worker (BullMQ)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["x", "turbo", "-F", "server", "dev:worker"],
      "port": 0,
      "autoPort": true
    },
    {
      "name": "Drizzle Studio",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "db:studio"],
      "port": 4983
    }
  ]
}
