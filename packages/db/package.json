{
  "name": "@workspace/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun --env-file ../../apps/server/.env ../../apps/server/src/seed/index.ts",
    "db:seed-employees": "bun --env-file ../../apps/server/.env ../../apps/server/src/seed/seed-employees.ts",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@workspace/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "catalog:",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@workspace/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
