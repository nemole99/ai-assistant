# ============================================================
# AI Assistant — Docker Compose environment
# cp .env.docker.example .env.docker   (then fill in the blanks)
# ============================================================

# --- PostgreSQL ---
# POSTGRES_* are used by the postgres container; DATABASE_URL must match them
POSTGRES_USER=aiassistant
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=aiassistant
DATABASE_URL=postgresql://aiassistant:change_me_postgres_password@postgres:5432/aiassistant

# --- Better Auth ---
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_hex_string_min_32_chars
# Must match the public URL users access the app from
BETTER_AUTH_URL=http://172.76.10.210:2103

# --- Default Admin Account (seeded on first run) ---
ADMIN_EMAIL=admin@company.local
ADMIN_PASSWORD=change_me_admin_password
DEFAULT_USER_PASSWORD=change_me_default_user_password

# --- Encryption (for AI provider credentials stored in DB) ---
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters
ENCRYPTION_KEY=change_me_to_64_hex_chars_0000000000000000000000000000000000000000000000

# --- CORS ---
CORS_ORIGIN=http://172.76.10.210:2103

# --- GitHub Copilot OAuth (default client ID is fine for internal use) ---
GITHUB_COPILOT_CLIENT_ID=Iv1.b507a08c87ecfe98

# --- System AI Provider: Ollama ---
# If Ollama runs on the Docker host machine, use host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Frontend build URL (must match the server's public address) ---
VITE_SERVER_URL=http://172.76.10.210:2103

# --- Node env ---
NODE_ENV=production
