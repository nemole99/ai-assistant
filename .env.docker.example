# ============================================================
# AI Assistant — Docker Compose environment
# cp .env.docker.example .env.docker   (then fill in the blanks)
# ============================================================

# --- PostgreSQL ---
# POSTGRES_* are used by the postgres container; DATABASE_URL must match them
POSTGRES_USER=aiassistant
POSTGRES_PASSWORD=password
POSTGRES_DB=aiassistant
DATABASE_URL=postgresql://aiassistant:password@postgres:5432/aiassistant
LEGACY_EVALUATION_DATABASE_URL=postgresql://aiassistant:aiassistant@172.76.10.246:5432/riskradar

# --- Better Auth ---
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=cfef69b22dee76d2b16e0dddce563e25629bf7b13981afce8f43fbb9a2cd7ea7
# Must match the public URL users access the app from
BETTER_AUTH_URL=http://localhost:2103

# --- Default Admin Account (seeded on first run) ---
ADMIN_EMAIL=admin@ewoosoft.com
ADMIN_PASSWORD=admin@1234
DEFAULT_USER_PASSWORD=evn@1234

# --- Encryption (for AI provider credentials stored in DB) ---
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters
ENCRYPTION_KEY=0e1f802d3ba87fbe60214a716f03e5d25b3fb4ef75a512f2a012ee09c905aa16

# --- CORS ---
CORS_ORIGIN=http://localhost:2103

# --- GitHub Copilot OAuth (default client ID is fine for internal use) ---
GITHUB_COPILOT_CLIENT_ID=Iv1.b507a08c87ecfe98

# --- System AI Provider: Ollama ---
# If Ollama runs on the Docker host machine, use host.docker.internal.
OLLAMA_BASE_URL=http://localhost:11434

# --- Frontend build URL (must match the server's public address) ---
VITE_SERVER_URL=http://localhost:2103

# --- Node env ---
NODE_ENV=production

# --- Redis (used by BullMQ worker queue) ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible object storage for documents) ---
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD: used by the MinIO container itself
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MINIO_ENDPOINT: internal hostname used by the server container to reach MinIO.
# In Docker this must be the service name "minio", NOT the public IP.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# MINIO_PUBLIC_ENDPOINT: public IP/hostname used to rewrite presigned URLs so
# browsers can download/upload files directly. Set to your server's IP or domain.
# Example: localhost
MINIO_PUBLIC_ENDPOINT=localhost
