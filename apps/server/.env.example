# Redis
REDIS_URL=redis://localhost:6379

# Document processing
# Full path to markitdown executable (needed if markitdown is not in PATH)
# Windows example: C:\Users\<user>\AppData\Local\Packages\PythonSoftwareFoundation.Python.3.11_qbz5n2kfra8p0\LocalCache\local-packages\Python311\Scripts\markitdown.exe
MARKITDOWN_PATH=markitdown