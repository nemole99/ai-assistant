{
  "name": "workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6.0.3",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.14.2",
      "@orpc/openapi": "^1.14.2",
      "@orpc/zod": "^1.14.2",
      "better-auth": "1.6.9",
      "ai": "^6.0.3",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.14.2",
      "@types/react-dom": "^19.2.3",
      "lucide-react": "^1.14.0",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.7",
      "@types/react": "^19.2.14",
      "tailwindcss": "^4.3.0",
      "drizzle-zod": "^0.8.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev dev:worker",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @workspace/db db:push",
    "db:seed": "turbo -F @workspace/db db:seed",
    "db:studio": "turbo -F @workspace/db db:studio",
    "db:generate": "turbo -F @workspace/db db:generate",
    "db:migrate": "turbo -F @workspace/db db:migrate",
    "db:start": "turbo -F @workspace/db db:start",
    "db:setup": "turbo -F @workspace/db db:setup",
    "db:watch": "turbo -F @workspace/db db:watch",
    "db:stop": "turbo -F @workspace/db db:stop",
    "db:down": "turbo -F @workspace/db db:down",
    "check": "ultracite check",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@workspace/env": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@workspace/config": "workspace:*",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.13"
}
